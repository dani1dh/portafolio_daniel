---
const { date, title, description } = Astro.props;
---

<li class="mb-10 ms-4">
  <div class="absolute w-3 h-3 bg-azul rounded-full mt-1.5 -inset-s-1.5"></div>
  <time class="text-sm md:text-base font-normal leading-none text-body"
    >{date}</time
  >
  <h3 class="text-lg md:text-xl font-semibold text-heading my-2">
    {title}
  </h3>
  <p class="mb-4 text-base md:text-lg font-normal text-body">
    {description}
  </p>
</li>
