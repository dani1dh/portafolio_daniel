---
interface Props {
  title: string;
  description: string;
  image: string;
  canonical?: string;
}

const { title, description, image, canonical } = Astro.props as Props;

const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
---

<meta
  name="keywords"
  content="desarrollo web, diseño web, apps móviles, desarrollo de sitios web, diseño de interfaces de usuario, desarrollo de aplicaciones móviles, experiencia de usuario, Back end, Developer"
/>
<meta charset="UTF-8" />
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="theme-color" content="#389EFF" />
<link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico" />
<link
  rel="icon"
  type="image/svg+xml"
  href="https://www.nexusinnovatix.com/images/NEXUS_logo.png"
/>
<meta name="author" content="Nexus Innovatix" />
<meta name="generator" content={Astro.generator} />
<meta name="og:image" content={new URL(image, Astro.url)} />
<meta name="og:title" content={title} />
<meta name="og:description" content={description} />
<meta name="og:url" content={Astro.url} />
<meta name="og:site_name" content="Nexus Innovatix" />
<meta name="og:type" content="website" />
<meta name="og:locale" content="es_ES" />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<title>{title}</title>
